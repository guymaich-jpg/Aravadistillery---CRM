rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuth() {
      return request.auth != null;
    }

    // Manager list — add your manager emails here.
    // Keep in sync with VITE_MANAGER_EMAILS env var.
    function isManager() {
      return isAuth() && request.auth.token.email in [
        // 'manager@example.com'
      ];
    }

    match /clients/{doc} {
      allow read, write: if isAuth();
    }
    match /orders/{doc} {
      allow read, write: if isAuth();
    }
    match /products/{doc} {
      allow read, write: if isAuth();
    }
    match /stockLevels/{doc} {
      allow read, write: if isAuth();
    }
    match /stockMovements/{doc} {
      allow read, write: if isAuth();
    }
    match /inventoryBatches/{doc} {
      allow read, write: if isAuth();
    }
    match /meta/{doc} {
      allow read, write: if isAuth();
    }

    // Invitations collection
    match /invitations/{token} {
      // Anyone can read a single invitation (guest validates their token before registering)
      allow get: if true;

      // Only managers can list all invitations
      allow list: if isManager();

      // Only managers can create invitations
      allow create: if isManager();

      // Authenticated users can update (invitee marks accepted, manager revokes)
      allow update: if isAuth() && (
        isManager() ||
        request.auth.token.email == resource.data.email
      );
    }

    // All other paths denied by default
  }
}
