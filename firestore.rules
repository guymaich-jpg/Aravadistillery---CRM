rules_version = '2';

// ═══════════════════════════════════════════════════════════════════
// MERGED Firestore Security Rules — Arava Distillery
// Firebase project: aravadistillery-crm (SHARED by CRM + Factory Control)
//
// ⚠️ SINGLE SOURCE OF TRUTH (C3 fix): this file is the union of the CRM
// and Factory Control rule sets. Keep the copy in BOTH repos identical
// (Aravadistillery---CRM/firestore.rules and
//  Aravadistillery-Factory-Control/firestore.rules).
// Deploying either repo's copy must be safe for both apps.
//
// Backend (Admin SDK) bypasses all rules — these apply only to
// client-side SDK access from the two web apps.
// ═══════════════════════════════════════════════════════════════════

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: caller is authenticated
    function isAuth() {
      return request.auth != null;
    }

    // Helper: manager or admin.
    // Accepts BOTH authorization systems in use:
    //  - role custom claims (set by the Factory backend / Admin SDK)
    //  - the email allowlist (legacy CRM managers who never received claims)
    // Must stay in sync with VITE_MANAGER_EMAILS.
    function isManager() {
      return isAuth() && (
        request.auth.token.role == 'admin' ||
        request.auth.token.role == 'manager' ||
        request.auth.token.email in ['guymaich@gmail.com', 'yonatangarini@gmail.com']
      );
    }

    // ── Factory production data ──────────────────────────────
    // Workers can read and create; managers can also update/delete.
    match /factory_rawMaterials/{docId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update, delete: if isManager();
    }
    match /factory_dateReceiving/{docId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update, delete: if isManager();
    }
    match /factory_fermentation/{docId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update, delete: if isManager();
    }
    match /factory_distillation1/{docId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update, delete: if isManager();
    }
    match /factory_distillation2/{docId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update, delete: if isManager();
    }
    match /factory_bottling/{docId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update, delete: if isManager();
    }
    match /factory_inventoryVersions/{docId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update, delete: if isManager();
    }
    match /factory_inventoryCounts/{docId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update, delete: if isManager();
    }
    match /factory_inventoryBase/{docId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update, delete: if isManager();
    }
    match /factory_inventoryDeclarations/{docId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update, delete: if isManager();
    }
    match /factory_customSuppliers/{docId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update, delete: if isManager();
    }

    // ── Factory inventory (singleton doc: current) ───────────
    // ⚠️ INTERIM: client writes allowed while the backend Admin SDK
    // credential (FIREBASE_PRIVATE_KEY on Vercel) is broken. Once the
    // backend writes succeed, tighten back to `write: if false`.
    match /factory_inventory/{docId} {
      allow read: if isAuth();
      allow write: if isAuth();
    }

    // ── Factory users ────────────────────────────────────────
    match /factory_users/{docId} {
      allow read: if isAuth();
      allow write: if isManager();
    }

    // ── Factory invitations ──────────────────────────────────
    // Managed via backend API (Admin SDK). No client-side writes.
    match /factory_invitations/{docId} {
      allow read: if isManager();
      allow write: if false;
    }

    // ── Factory custom options (dropdown values) ─────────────
    match /factory_customOptions/{docId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isManager();
      allow delete: if isManager();
    }

    // ── Factory quick access ─────────────────────────────────
    // Managed via backend API. No direct client writes.
    match /factory_quickAccess/{docId} {
      allow read: if isAuth();
      allow write: if false;
    }

    // ── Stock levels (Factory → CRM sync) ────────────────────
    // ⚠️ INTERIM: client writes allowed while the backend Admin SDK
    // credential (FIREBASE_PRIVATE_KEY on Vercel) is broken — the Factory
    // web app is currently the only working writer. Once the backend
    // writes succeed, tighten back to `write: if false` (single-writer).
    match /stockLevels/{docId} {
      allow read: if isAuth();
      allow write: if isAuth();
    }

    // ── CRM clients (soft-delete design; hard delete manager-only) ──
    match /clients/{docId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAuth();
      allow delete: if isManager();
    }

    // ── CRM orders ───────────────────────────────────────────
    match /orders/{docId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAuth();
      allow delete: if isManager();
    }

    // ── Products — managers modify, all read ─────────────────
    match /products/{docId} {
      allow read: if isAuth();
      allow write: if isManager();
    }

    // ── Stock movements — append-only audit trail ────────────
    match /stockMovements/{docId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update, delete: if false; // Immutable
    }

    // ── Inventory batches ────────────────────────────────────
    match /inventoryBatches/{docId} {
      allow read: if isAuth();
      allow write: if isManager();
    }

    // ── Audit log — append only ──────────────────────────────
    match /audit_log/{docId} {
      allow read: if isManager();
      // userEmail must match the writer's own token — without this, any
      // authed client could forge an entry under someone else's identity.
      // Existing entries are still fully immutable (no update/delete).
      allow create: if isAuth() &&
        request.resource.data.userEmail == request.auth.token.email;
      allow update, delete: if false; // Immutable
    }

    // ── CRM user invitations ─────────────────────────────────
    match /invitations/{docId} {
      // A brand-new user has no Firestore auth yet when they open their
      // invite link — validateInvitation() must run unauthenticated. The
      // doc id (token) is a crypto.randomUUID(), i.e. the actual secret;
      // a single-doc get by exact id is safe to leave open. Enumerating
      // the whole collection stays manager-only.
      allow get: if true;
      allow list: if isManager();
      allow create, delete: if isManager();
      // Self-service accept: the newly-registered user (now authenticated,
      // not yet a manager) must be able to flip their OWN pending invite to
      // accepted — narrowly scoped to that one transition, only the
      // lifecycle fields, and only by the email the invite was issued to.
      allow update: if isManager() || (
        isAuth() &&
        resource.data.status == 'pending' &&
        request.resource.data.status == 'accepted' &&
        resource.data.email == request.auth.token.email &&
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['status', 'acceptedAt', 'userName'])
      );
    }

    // ── Users ────────────────────────────────────────────────
    match /users/{docId} {
      allow read: if isAuth();
      allow write: if isManager();
    }

    // ── Schema metadata — authoritative migration version ────
    // All authed users must read it so fresh devices skip the
    // CRM migration chain (C1 fix).
    match /meta/{docId} {
      allow read: if isAuth();
      allow write: if isManager();
    }

    // ── Default deny ─────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
