rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: check if user is authenticated
    function isAuth() {
      return request.auth != null;
    }

    // Helper: check role claim (stored in custom claims)
    function hasRole(role) {
      return isAuth() && request.auth.token.role == role;
    }

    function isManager() {
      return hasRole('manager') || hasRole('admin');
    }

    function isAdmin() {
      return hasRole('admin');
    }

    // Stock levels — Factory Control writes, CRM reads
    match /stockLevels/{docId} {
      allow read: if isAuth();
      allow write: if isAuth(); // Factory service account or admin
    }

    // Clients — authenticated CRM users
    match /clients/{docId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAuth();
      allow delete: if isManager(); // Only managers can delete
    }

    // Orders — authenticated CRM users
    match /orders/{docId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAuth();
      allow delete: if isManager();
    }

    // Products — managers can modify, all can read
    match /products/{docId} {
      allow read: if isAuth();
      allow write: if isManager();
    }

    // Stock movements — append only (no updates/deletes)
    match /stockMovements/{docId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update, delete: if false; // Immutable audit trail
    }

    // Inventory batches — managers can manage
    match /inventoryBatches/{docId} {
      allow read: if isAuth();
      allow write: if isManager();
    }

    // Audit log — append only, admins can read
    match /audit_log/{docId} {
      allow read: if isManager();
      allow create: if isAuth();
      allow update, delete: if false; // Immutable
    }

    // User invitations — managers can manage
    match /invitations/{docId} {
      allow read: if isAuth();
      allow write: if isManager();
    }

    // Schema metadata — authoritative migration version (meta/schema).
    // All authed users must read it so fresh devices skip the migration chain.
    match /meta/{docId} {
      allow read: if isAuth();
      allow write: if isManager();
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
