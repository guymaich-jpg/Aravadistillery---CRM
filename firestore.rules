rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuth() {
      return request.auth != null;
    }

    match /clients/{doc} {
      allow read, write: if isAuth();
    }
    match /orders/{doc} {
      allow read, write: if isAuth();
    }
    match /products/{doc} {
      allow read, write: if isAuth();
    }
    match /stockLevels/{doc} {
      allow read, write: if isAuth();
    }
    match /stockMovements/{doc} {
      allow read, write: if isAuth();
    }
    match /inventoryBatches/{doc} {
      allow read, write: if isAuth();
    }
    match /meta/{doc} {
      allow read, write: if isAuth();
    }
    // Access requests — guests can create, only authenticated users can read/update
    match /accessRequests/{doc} {
      allow create: if true;
      allow read, update: if isAuth();
      allow delete: if false;
    }
    // All other paths denied by default
  }
}
