# ─── Auth0 SSO Configuration ───────────────────────────────────────────────
# Copy this file to .env.local for local development.
# In production (GitHub Actions), set these as GitHub Secrets:
#   GitHub repo → Settings → Secrets and variables → Actions → New repository secret

# Your Auth0 tenant domain — found in Auth0 Dashboard → Applications → Settings
# Example: your-company.auth0.com
VITE_AUTH0_DOMAIN=

# Your Auth0 Single Page Application client ID — same location as above
VITE_AUTH0_CLIENT_ID=

# ─── Auth0 Setup Checklist ──────────────────────────────────────────────────
# 1. Go to https://auth0.com and create a free account
# 2. Create Application → Single Page Application
# 3. In "Allowed Callback URLs":
#      https://guymaich-jpg.github.io/Aravadistillery---CRM/,
#      http://localhost:5173/
# 4. In "Allowed Logout URLs":
#      https://guymaich-jpg.github.io/Aravadistillery---CRM/,
#      http://localhost:5173/
# 5. In "Allowed Web Origins":
#      https://guymaich-jpg.github.io,
#      http://localhost:5173
# 6. Enable Social Connections (Google, Microsoft, etc.) in Auth0 → Authentication → Social
# 7. (Optional) Enable Organizations for enterprise SSO / team management
# 8. Add VITE_AUTH0_DOMAIN and VITE_AUTH0_CLIENT_ID as GitHub Secrets
# 9. In GitHub repo → Settings → Pages → Source → GitHub Actions
