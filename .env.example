# ─── Firebase Configuration ─────────────────────────────────────────────────
# Copy this file to .env.local for local development.
# In production (GitHub Actions), set these as GitHub Secrets.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ─── Admin Contact ────────────────────────────────────────────────────────────
# Email shown in "Request Access" mailto link (comma-separated for multiple)
VITE_ADMIN_EMAIL=

# ─── Manager Emails ──────────────────────────────────────────────────────────
# Comma-separated emails of users who can invite new users via the Management tab
VITE_MANAGER_EMAILS=

# ─── Firebase Setup Checklist ───────────────────────────────────────────────
# 1. Go to https://console.firebase.google.com and create a project
# 2. Enable Firestore Database (production mode)
# 3. Enable Authentication → Email/Password provider
# 4. Create users in the Firebase Auth console
# 5. Register a Web App and copy the config values above
# 6. Deploy Firestore security rules (see firestore.rules)
# 7. Add these vars as GitHub Secrets for CI/CD deployment
#
# For separate QA/Prod environments, create two Firebase projects
# and use QA_FIREBASE_* / PROD_FIREBASE_* secrets in GitHub Actions.
